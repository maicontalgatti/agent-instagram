# News API Key (https://newsapi.org/)
NEWS_API_KEY=your_news_api_key

# OpenAI API Key (https://platform.openai.com/)
OPENAI_API_KEY=your_openai_api_key

# Cloudinary Credentials (https://cloudinary.com/)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Instagram Graph API Credentials (https://developers.facebook.com/)
INSTAGRAM_ACCESS_TOKEN=your_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# Opcional: URL HTTPS pública de uma imagem (modo teste em main.py). Se definida, não usa Cloudinary.
# DEFAULT_POST_IMAGE_URL=https://exemplo.com/imagem.jpg
